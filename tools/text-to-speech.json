{
  "name": "text-to-speech",
  "description": "Convert text to speech via GMI Cloud (ElevenLabs, MiniMax TTS, Inworld)",
  "input_schema": {
    "type": "object",
    "properties": {
      "text": {
        "type": "string",
        "description": "Text to convert to speech"
      },
      "model": {
        "type": "string",
        "description": "TTS model (e.g., 'elevenlabs-tts-v3', 'minimax-tts-speech-2.6-turbo')"
      },
      "voice": {
        "type": "string",
        "description": "Voice ID or name",
        "default": "default"
      }
    },
    "required": ["text"]
  }
}
