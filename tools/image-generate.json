{
  "name": "image-generate",
  "description": "Generate images from a text prompt via GMI Cloud (Nano Banana 2, Seedream, GLM-Image, FLUX)",
  "input_schema": {
    "type": "object",
    "properties": {
      "prompt": {
        "type": "string",
        "description": "Text description of the image to generate"
      },
      "model": {
        "type": "string",
        "description": "Model ID (e.g., 'Seedream-5.0-lite', 'gemini-3-pro-image-preview', 'GLM-Image')"
      },
      "size": {
        "type": "string",
        "description": "Image size (e.g., '1024x1024', '512x512')",
        "default": "1024x1024"
      },
      "num_images": {
        "type": "integer",
        "description": "Number of images to generate (1-4)",
        "default": 1
      }
    },
    "required": ["prompt"]
  }
}
