{
  "name": "speech-to-text",
  "description": "Transcribe audio to text via GMI Cloud (Whisper large v3)",
  "input_schema": {
    "type": "object",
    "properties": {
      "audio_path": {
        "type": "string",
        "description": "Path to the audio file to transcribe (mp3, wav, m4a, webm)"
      },
      "model": {
        "type": "string",
        "description": "STT model (e.g., 'whisper-large-v3')"
      },
      "language": {
        "type": "string",
        "description": "Language code (e.g., 'en', 'es'). Auto-detected if omitted."
      }
    },
    "required": ["audio_path"]
  }
}
