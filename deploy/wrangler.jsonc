// wrangler.jsonc — AgentOS Cloudflare Agents deployment (modernized)
{
  "name": "agentos",
  "main": "src/index.ts",
  "compatibility_date": "2026-03-01",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1
  },

  // Static frontend assets (portal SPA)
  "assets": {
    "directory": "./public/",
    "not_found_handling": "single-page-application",
    "binding": "ASSETS"
  },

  // Durable Objects — AgentOS agents + MCP server
  "durable_objects": {
    "bindings": [
      {
        "name": "AGENTOS_AGENT",
        "class_name": "AgentOSAgent"
      },
      {
        "name": "AGENTOS_MCP",
        "class_name": "AgentOSMcpServer"
      }
    ]
  },

  // SQLite migration for Agent + MCP state persistence
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["AgentOSAgent", "AgentOSMcpServer"]
    }
  ],

  // Workers AI binding for LLM inference and embeddings
  "ai": {
    "binding": "AI"
  },

  // Vectorize for semantic memory / RAG
  "vectorize": [
    {
      "binding": "VECTORIZE",
      "index_name": "agentos-knowledge"
    }
  ],

  // AI Gateway for multi-provider routing and observability
  "ai_gateway": {
    "binding": "AI_GATEWAY",
    "gateway_id": "agentos-gateway"
  },

  // Environment variables (secrets set via `wrangler secret put`)
  "vars": {
    "DEFAULT_PROVIDER": "workers-ai",
    "DEFAULT_MODEL": "@cf/meta/llama-3.3-70b-instruct-fp8-fast"
  }
}
