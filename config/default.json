{
  "harness": {
    "max_turns": 50,
    "timeout_seconds": 300,
    "retry_on_tool_failure": true,
    "max_retries": 3
  },
  "llm": {
    "default_model": "claude-sonnet-4-6-20250627",
    "routing": {
      "simple": {
        "model": "openai/gpt-4o-mini",
        "provider": "gmi",
        "max_tokens": 1024
      },
      "moderate": {
        "model": "deepseek-ai/DeepSeek-V3.2",
        "provider": "gmi",
        "max_tokens": 4096
      },
      "complex": {
        "model": "anthropic/claude-sonnet-4.6",
        "provider": "gmi",
        "max_tokens": 8192
      },
      "tool_call": {
        "model": "anthropic/claude-haiku-4.5",
        "provider": "gmi",
        "max_tokens": 4096
      },
      "vision": {
        "model": "anthropic/claude-sonnet-4.6",
        "provider": "gmi",
        "max_tokens": 4096
      },
      "image_gen": {
        "model": "seedream-5.0-lite",
        "provider": "gmi-requestqueue"
      },
      "tts": {
        "model": "elevenlabs-tts-v3",
        "provider": "gmi-requestqueue"
      },
      "stt": {
        "model": "@cf/openai/whisper",
        "provider": "cloudflare"
      }
    },
